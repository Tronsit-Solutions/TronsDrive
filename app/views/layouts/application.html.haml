!!! 5
%html
  %head
    %title= content_for?(:title) ? yield(:title) : "TronsDrive – Rent a Car Anywhere | Luxury, Economy & SUV Rentals"
    %meta{ name: "description", content: content_for?(:description) ? yield(:description) : "TronsDrive makes car rental effortless. Choose from economy, luxury, sports, SUV and electric vehicles worldwide. Zero deposit options, self-drive or with driver, instant booking." }
    %meta{ name: "google-site-verification", content: "wvn6cT86Y1qMX6mhUixnS6TRGZYSto-J2SvFUHMqk10" }
    %link{ rel: "canonical", href: content_for?(:canonical) ? yield(:canonical) : "#{request.base_url}#{request.path}" }
    = render 'layouts/structured_data'
    = favicon_link_tag 'new_logo.png'
    %meta{ name: "viewport", content: "width=device-width,initial-scale=1" }
    = csrf_meta_tags
    = csp_meta_tag
    = yield :head
    / Anti-flash: apply saved theme before first paint
    :javascript
      (function() {
        try {
          var t = localStorage.getItem('td-theme');
          if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          if (t === 'dark') document.documentElement.classList.add('dark');
        } catch(e) {}
      })();
    %link{ rel: "preconnect", href: "https://js.stripe.com", crossorigin: "anonymous" }
    %link{ rel: "preconnect", href: "https://m.stripe.network", crossorigin: "anonymous" }
    %link{ rel: "preconnect", href: "https://cdn.jsdelivr.net", crossorigin: "anonymous" }
    %link{ rel: "preconnect", href: "https://cdnjs.cloudflare.com", crossorigin: "anonymous" }
    %link{ rel: "preconnect", href: "https://www.googletagmanager.com", crossorigin: "anonymous" }
    %link{ rel: "preconnect", href: "https://www.clarity.ms", crossorigin: "anonymous" }
    %link{ href: "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css", rel: "stylesheet", integrity: "sha384-nRgPTkuX86pH8yjPJUAFuASXQSSl2/bBUiNV47vSYpKFxHJhbcrGnmlYpYJMeD7a", crossorigin: "anonymous" }
    %script{ src: "https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js", integrity: "sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM", crossorigin: "anonymous" }
    %script{ src: "https://js.stripe.com/v3/", defer: true }
    = javascript_importmap_tags
    = stylesheet_link_tag "tailwind", "data-turbo-track": "reload"
    = stylesheet_link_tag "application", "data-turbo-track": "reload"
    / Google Tag Manager
    :javascript
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-KHNRX3WS');
    :javascript
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "tun0jube3z");
    :css
      .swiper-container { width:100%; height:100%; }
      .swiper-slide { text-align:center; background:transparent; display:flex; justify-content:center; align-items:center; }
      .swiper-button-next, .swiper-button-prev { color:#F97316; background:rgba(255,255,255,0.85); width:44px; height:44px; border-radius:50%; transition:all 0.3s ease; }
      .swiper-button-next:hover, .swiper-button-prev:hover { background:#F97316; color:#fff; transform:scale(1.1); }
      .swiper-pagination-bullet { background:#F97316; opacity:0.7; }
      .swiper-pagination-bullet-active { opacity:1; }
      .current-slide { font-weight:bold; }
  %body{ style: "background-color: var(--td-bg); color: var(--td-text);", class: ("has-announcement" if Announcement.current&.visible?) }
    %noscript
      %iframe{ src: "https://www.googletagmanager.com/ns.html?id=GTM-KHNRX3WS", height: "0", width: "0", style: "display:none;visibility:hidden" }
    = render 'shared/whatsapp_button'
    %header.fixed.top-0.left-0.right-0.z-50{ role: "banner" }
      = render 'layouts/announcement_bar'
      = render 'layouts/navbar'
    %main{ role: "main" }
      = render 'shared/flash_messages'
      = yield
    = render 'shared/loader'
    - if content_for?(:footer)
      = yield :footer
    - else
      = render 'shared/footer'
