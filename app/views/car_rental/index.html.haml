- content_for :head do
  %link{ rel: "preload", href: asset_path('hero_cars/hero_1.jpg'), as: "image" }
  %link{ rel: "preload", href: asset_path('hero_cars/hero_2.jpg'), as: "image" }
  %link{ rel: "preload", href: asset_path('hero_cars/hero_3.jpg'), as: "image" }
  %link{ rel: "preload", href: asset_path('hero_cars/hero_4.jpg'), as: "image" }
  %link{ rel: "preload", href: asset_path('hero_cars/car3.png'), as: "image" }
  %link{ rel: "preload", href: asset_path('hero_cars/car4.png'), as: "image" }
  %link{ rel: "preload", href: asset_path('new_logo.png'), as: "image" }
  %link{ rel: "preload", href: asset_path('tabby_banner.jpg'), as: "image" }
  %link{ rel: "preload", href: asset_path('no_deposit_banner.jpg'), as: "image" }
  %link{ rel: "preload", href: asset_path('join_us_image.png'), as: "image" }

%div{ style: "background: var(--td-bg); min-height: 100vh;" }

  / ═══════════════════════════════════════════════════════
  / HERO
  / ═══════════════════════════════════════════════════════
  %section.relative.text-white.pt-16{ style: 'height: 100vh; background: linear-gradient(135deg, #0F172A 0%, #1E293B 60%, #0F172A 100%)' }
    #heroImageSlider.absolute.inset-0
      %img.absolute.inset-0.w-full.h-full.object-cover.object-center.transition-opacity.duration-1000.opacity-100{ src: asset_path('hero_cars/hero_1.jpg'), alt: 'Hero 1', 'data-index' => '0' }
      %img.absolute.inset-0.w-full.h-full.object-cover.object-center.transition-opacity.duration-1000.opacity-0{ src: asset_path('hero_cars/hero_2.jpg'), alt: 'Hero 2', 'data-index' => '1' }
      %img.absolute.inset-0.w-full.h-full.object-cover.object-center.transition-opacity.duration-1000.opacity-0{ src: asset_path('hero_cars/hero_3.jpg'), alt: 'Hero 3', 'data-index' => '2' }
      %img.absolute.inset-0.w-full.h-full.object-cover.object-center.transition-opacity.duration-1000.opacity-0{ src: asset_path('hero_cars/hero_4.jpg'), alt: 'Hero 4', 'data-index' => '3' }
    .absolute.inset-0{ style: "background: linear-gradient(to bottom, rgba(10,15,30,0.55) 0%, rgba(10,15,30,0.75) 60%, rgba(15,23,42,0.95) 100%)" }

    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8.relative.z-10.h-full.flex.items-center
      .w-full.grid.grid-cols-1.lg:grid-cols-2.gap-10.items-center.pt-10
        / Left — headline
        .order-2.lg:order-1
          .inline-flex.items-center.space-x-2.mb-5.px-3.py-1.rounded-full.text-xs.font-bold.uppercase.tracking-widest{ style: "background: rgba(249,115,22,0.15); color: #F97316; border: 1px solid rgba(249,115,22,0.3)" }
            %i.fas.fa-globe.text-xs
            %span Global Car Rentals
          %h1.text-4xl.md:text-5xl.xl:text-6xl.font-extrabold.leading-tight.mb-4
            = (@headline || 'Drive Anywhere.')
            %br
            %span{ style: "color: #F97316" } Your Car, Your Route.
          %p.text-base.md:text-lg.mb-8.max-w-xl{ style: "color: rgba(255,255,255,0.80)" }
            TronsDrive connects you with premium vehicles worldwide — economy, luxury, SUV, electric and everything in between. Zero hassle, instant booking.
          .flex.flex-wrap.gap-4.mt-2
            = link_to (@cars_path || cars_path), style: 'display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.85rem 2rem; border-radius: 9999px; font-weight: 700; font-size: 0.95rem; color: #fff; background: linear-gradient(135deg, #F97316 0%, #EA580C 100%); box-shadow: 0 8px 28px rgba(249,115,22,0.45), inset 0 1px 0 rgba(255,255,255,0.2); letter-spacing: 0.01em; transition: transform 0.2s ease, box-shadow 0.2s ease; text-decoration: none;', onmouseover: "this.style.transform='translateY(-2px)'; this.style.boxShadow='0 14px 36px rgba(249,115,22,0.55), inset 0 1px 0 rgba(255,255,255,0.2)'", onmouseout: "this.style.transform=''; this.style.boxShadow='0 8px 28px rgba(249,115,22,0.45), inset 0 1px 0 rgba(255,255,255,0.2)'" do
              .w-7.h-7.rounded-full.flex.items-center.justify-center{ style: 'background: rgba(255,255,255,0.2); flex-shrink: 0;' }
                %i.fas.fa-car-side.text-xs
              %span= (@cta_label || 'Browse Cars')
            = link_to cars_path(with_driver: true), style: 'display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.85rem 2rem; border-radius: 9999px; font-weight: 600; font-size: 0.95rem; color: #fff; background: rgba(255,255,255,0.08); border: 1.5px solid rgba(255,255,255,0.3); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); letter-spacing: 0.01em; transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease; text-decoration: none;', onmouseover: "this.style.transform='translateY(-2px)'; this.style.background='rgba(255,255,255,0.15)'; this.style.borderColor='rgba(255,255,255,0.5)'", onmouseout: "this.style.transform=''; this.style.background='rgba(255,255,255,0.08)'; this.style.borderColor='rgba(255,255,255,0.3)'" do
              .w-7.h-7.rounded-full.flex.items-center.justify-center{ style: 'background: rgba(255,255,255,0.15); flex-shrink: 0;' }
                %i.fas.fa-user-tie.text-xs
              %span With Driver

        / Right — trust badges
        .order-1.lg:order-2
          .grid.grid-cols-2.gap-3
            - [['fas fa-shield-alt','Zero Deposit','Options available'],['fas fa-clock','24/7 Support','Always here'],['fas fa-globe','Worldwide','Any city, any country'],['fas fa-star','Top Rated','5-star experience']].each do |icon, title, sub|
              .rounded-2xl.p-4{ style: "background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); backdrop-filter: blur(12px)" }
                %i{ class: "#{icon} text-xl mb-2 block", style: "color: #F97316" }
                %p.text-sm.font-bold.text-white= title
                %p.text-xs{ style: "color: rgba(255,255,255,0.6)" }= sub

  / ═══════════════════════════════════════════════════════
  / FILTER BAR
  / ═══════════════════════════════════════════════════════
  = render 'car_rental/filters'

  / ═══════════════════════════════════════════════════════
  / TAGLINE
  / ═══════════════════════════════════════════════════════
  %section.py-10{ style: "background: var(--td-surface)" }
    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8.text-center
      %p.text-base.md:text-lg.leading-relaxed.max-w-4xl.mx-auto{ style: "color: var(--td-muted)" }
        TronsDrive offers a comprehensive range of vehicles for every occasion — from daily commuters to luxury escapes. Whether you are travelling for tourism, business, or adventure, book instantly with flexible options including zero deposit, self-drive, or chauffeured service.

  / ═══════════════════════════════════════════════════════
  / PROMO BANNER
  / ═══════════════════════════════════════════════════════
  %section.py-6{ style: "background: var(--td-bg)" }
    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
      .relative.rounded-2xl.overflow-hidden.border.shadow-sm.hover:shadow-md.transition-shadow{ style: "border-color: var(--td-border)" }
        #promoSlider.relative.w-full{ class: 'h-24 sm:h-32 md:h-40 lg:h-56', style: 'min-height: 6rem;' }
          %img.absolute.inset-0.w-full.h-full.object-cover.transition-opacity.duration-700.opacity-100{ src: image_path('tabby_banner.jpg'), alt: 'Tabby', 'data-index' => '0' }
          %img.absolute.inset-0.w-full.h-full.object-cover.transition-opacity.duration-700.opacity-0{ src: image_path('no_deposit_banner.jpg'), alt: 'No deposit', 'data-index' => '1' }

  / ═══════════════════════════════════════════════════════
  / CAR CLASSES GRID
  / ═══════════════════════════════════════════════════════
  %section.py-16{ style: "background: var(--td-surface2)" }
    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
      .text-center.mb-10
        %span.inline-block.text-xs.font-bold.uppercase.tracking-widest.mb-3.px-3.py-1.rounded-full{ style: "background: rgba(249,115,22,0.12); color: #F97316" } Categories
        %h2.text-3xl.md:text-4xl.font-extrabold{ style: "color: var(--td-text)" } Choose Your Drive
      .grid.grid-cols-2.md:grid-cols-3.gap-6.md:gap-8
        - (@car_classes || []).each do |car_class|
          = link_to cars_path(category: (car_class[:slug] || car_class[:name])), class: 'group relative rounded-2xl overflow-hidden h-48 transition-all duration-300 category-tile' do
            .absolute.inset-0
              %img.w-full.h-full.object-cover.group-hover:scale-105.transition-transform.duration-500{ src: car_class[:image], alt: car_class[:name] }
            .absolute.inset-0{ style: "background: linear-gradient(to top, rgba(10,15,30,0.85) 0%, rgba(10,15,30,0.2) 100%)" }
            .absolute.inset-0.flex.items-end.p-4
              .flex.items-center.justify-between.w-full
                %h3.text-lg.font-bold.text-white= car_class[:name]
                .w-8.h-8.rounded-full.flex.items-center.justify-center{ style: "background: rgba(249,115,22,0.85)" }
                  %i.fas.fa-arrow-right.text-white.text-xs

  / ═══════════════════════════════════════════════════════
  / CAR CAROUSELS
  / ═══════════════════════════════════════════════════════
  - (@categories_to_display).each do |category|
    %section.py-12{ style: "background: var(--td-bg)" }
      .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
        .flex.items-center.justify-between.mb-6.flex-wrap.gap-4
          %div.flex-1
            %h2.text-2xl.md:text-3xl.font-extrabold.mb-1{ style: "color: var(--td-text)" }
              - if category[:slug] == 'featured'
                = category[:name]
              - else
                = link_to category[:name], cars_path(category: category[:name]), style: "color: var(--td-text); text-decoration: none"
            %p.text-sm{ style: "color: var(--td-muted)" }= category[:description]
          - unless category[:slug] == 'featured'
            - link_path = category[:with_driver] ? cars_path(with_driver: true) : cars_path(category: category[:slug])
            = link_to link_path, class: 'inline-flex items-center rounded-xl font-semibold px-5 py-2.5 text-sm shadow transition hover:scale-105', style: 'background: linear-gradient(135deg, #F97316, #EA580C); color: white; box-shadow: 0 4px 14px rgba(249,115,22,0.3)' do
              View More
              %i.fas.fa-arrow-right.ml-2

        .car-carousel.mt-4
          - if category[:slug] == 'with-driver'
            - category_cars = (@category_cars || []).select { |c| c.with_driver? }.uniq
          - elsif category[:slug] == 'featured'
            - category_cars = @featured_cars || []
          - else
            - category_cars = (@category_cars || []).select { |c| c[:category]&.include?(category[:slug]) }
          - category_cars = category_cars.presence || []

          - if category_cars.any?
            - cache [ "v2", "category_carousel", category[:slug], @max_cards, category_cars.map(&:id), category_cars.map(&:updated_at).max ] do
              .relative{ id: "carousel-#{category[:slug]}" }
                %button.absolute.left-0.transform.z-10.w-11.h-11.rounded-full.shadow-xl.transition-all.duration-300.hidden.carousel-nav-btn.carousel-prev{ class: 'top-1/2 -translate-y-1/2 -translate-x-4 hover:scale-110', style: 'background: linear-gradient(135deg,#F97316,#EA580C)', data: { category: category[:slug] } }
                  %i.fas.fa-chevron-left.text-white
                - if category_cars.length > @max_cards
                  %button.absolute.right-0.transform.z-10.w-11.h-11.rounded-full.shadow-xl.transition-all.duration-300.carousel-nav-btn.carousel-next{ class: 'top-1/2 -translate-y-1/2 translate-x-4 hover:scale-110', style: 'background: linear-gradient(135deg,#F97316,#EA580C)', data: { category: category[:slug] } }
                    %i.fas.fa-chevron-right.text-white
                .carousel-viewport.overflow-hidden.w-full
                  .carousel-track.flex.transition-transform.duration-500.ease-in-out.py-2{ style: "align-items: stretch;", data: { category: category[:slug], current: '0', total: category_cars.length } }
                    - category_cars.each_with_index do |car, index|
                      .carousel-item.flex-shrink-0.px-2.5{ style: "display: flex;" }
                        = link_to car_path(car), class: 'rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 flex flex-col', style: "background: var(--td-surface); border: 1px solid var(--td-border); box-shadow: var(--td-card-shadow); width: 100%;" do
                          .relative.h-48.overflow-hidden{ style: "background: var(--td-surface2)" }
                            = car_main_image(car, size: [400, 300])
                            .absolute.top-2.left-2.z-10.flex.flex-col.gap-1
                              - if car.featured?
                                %span.inline-flex.items-center.px-2.py-0.5.rounded-full.text-xs.font-bold{ style: "background: #FBBF24; color: #0F172A" }
                                  %i.fas.fa-star.mr-1.text-xs
                                  Featured
                              - if car.has_discount?
                                %span.inline-flex.items-center.px-2.py-0.5.rounded-full.text-xs.font-bold.text-white{ style: "background: linear-gradient(135deg,#EF4444,#DC2626)" }
                                  %i.fas.fa-tag.mr-1.text-xs
                                  = "#{car.discount_percentage}% OFF"
                              - if car.with_driver?
                                %span.inline-flex.items-center.px-2.py-0.5.rounded-full.text-xs.font-bold.text-white{ style: "background: #3B82F6" }
                                  %i.fas.fa-user-tie.mr-1.text-xs
                                  With Driver
                            .absolute.top-2.right-2
                              - status_style = car.status == 'Available' ? 'background: #22C55E; color: white' : 'background: #EF4444; color: white'
                              %span.inline-block.rounded-full.text-xs.font-semibold.px-2.py-1{ style: status_style }= car.status
                          .p-4{ style: "flex: 1; display: flex; flex-direction: column; justify-content: space-between;" }
                            %div
                              .flex.items-start.justify-between.mb-1
                                %h3.text-base.font-bold{ style: "color: var(--td-text)" }
                                  - if car.category == 'Limousine'
                                    = car.brand
                                  - else
                                    = "#{car.brand} #{car.model}"
                                - unless car.category == 'Limousine'
                                  %span.text-xs{ style: "color: var(--td-muted)" }= car.year
                              %p.text-xs.mb-3{ style: "color: var(--td-muted)" }
                                - if car.category == 'Limousine'
                                  Limousine Service
                                - else
                                  = car.color
                                  - if car.with_driver?
                                    = " · #{car.seats || 5} Seats · #{car.luggage_capacity || 0} Bags"
                                  - elsif car.category.present?
                                    = " · #{car.category}"
                            .flex.items-baseline.justify-between{ style: "min-height: 3rem;" }
                              .flex.flex-col{ style: "justify-content: flex-end;" }
                                - if car.category == 'Limousine'
                                  - if car.has_discount?
                                    %span.text-xs.line-through{ style: "color: var(--td-muted)" }= "AED #{car.hourly_price}"
                                    %span.text-xl.font-extrabold.text-red-500= "AED #{car.discounted_hourly_price.round(2)}"
                                  - else
                                    %span.text-xl.font-extrabold{ style: "color: #F97316" }= "AED #{car.hourly_price}"
                                - elsif car.with_driver?
                                  - if car.has_discount?
                                    %span.text-xs.line-through{ style: "color: var(--td-muted)" }= "AED #{car.five_hours_charge}"
                                    %span.text-xl.font-extrabold.text-red-500= "AED #{car.discounted_five_hours_charge.round(2)}"
                                  - else
                                    %span.text-xl.font-extrabold{ style: "color: #F97316" }= car.five_hours_charge ? "AED #{car.five_hours_charge}" : 'AED 0'
                                - elsif car.has_discount?
                                  %span.text-xs.line-through{ style: "color: var(--td-muted)" }= number_to_currency(car.daily_price)
                                  %span.text-xl.font-extrabold.text-red-500= number_to_currency(car.discounted_daily_price)
                                - else
                                  %span.text-xl.font-extrabold{ style: "color: #F97316" }= car.daily_price ? number_to_currency(car.daily_price) : 'N/A'
                              %span.text-xs{ style: "color: var(--td-muted)" }
                                - if car.category == 'Limousine'
                                  \/hr
                                - elsif car.with_driver?
                                  \/5h
                                - else
                                  \/day
          - else
            .text-center.py-12
              %i.fas.fa-car-side.text-4xl.mb-3.block{ style: "color: var(--td-border)" }
              %p.text-lg{ style: "color: var(--td-muted)" } No cars available in this category right now.

    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
      %hr{ style: "border-color: var(--td-border)" }

  / ═══════════════════════════════════════════════════════
  / STATS
  / ═══════════════════════════════════════════════════════
  %section.py-20{ style: "background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%)" }
    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
      .text-center.mb-12
        %h2.text-3xl.md:text-4xl.font-extrabold.text-white.mb-2 Trusted by Thousands
        %p{ style: "color: rgba(255,255,255,0.55)" } Across multiple cities and growing every day
      .grid.grid-cols-1.md:grid-cols-3.gap-6.text-center
        - default_stats = [{value: '990+', label: 'Bookings Completed', icon: 'fa-calendar-check'}, {value: '230+', label: 'Cars in Fleet', icon: 'fa-car'}, {value: '660+', label: 'Happy Customers', icon: 'fa-thumbs-up'}]
        - (@stats || default_stats).each do |s|
          .rounded-2xl.p-8{ style: "background: rgba(255,255,255,0.05); border: 1px solid rgba(249,115,22,0.2)" }
            .w-16.h-16.rounded-2xl.flex.items-center.justify-center.mx-auto.mb-4{ style: "background: linear-gradient(135deg, #F97316, #EA580C)" }
              %i{ class: "fas #{s[:icon]} text-white text-2xl" }
            %div.text-4xl.font-extrabold.mb-1{ style: "color: #F97316" }= s[:value]
            %div.text-sm.font-medium{ style: "color: rgba(255,255,255,0.65)" }= s[:label]

  / ═══════════════════════════════════════════════════════
  / RENTAL REQUIREMENTS
  / ═══════════════════════════════════════════════════════
  %section.py-16{ style: "background: var(--td-bg)" }
    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
      .text-center.mb-10
        %span.inline-block.text-xs.font-bold.uppercase.tracking-widest.mb-3.px-3.py-1.rounded-full{ style: "background: rgba(249,115,22,0.12); color: #F97316" } Requirements
        %h2.text-3xl.font-extrabold.mb-2{ style: "color: var(--td-text)" } What You Need to Rent
      .grid.grid-cols-1.lg:grid-cols-2.gap-6
        / Residents
        .rounded-2xl.overflow-hidden.border{ style: "background: var(--td-surface); border-color: var(--td-border)" }
          .px-6.py-4.border-b{ style: "background: linear-gradient(135deg, #F97316, #EA580C); border-color: transparent" }
            %h3.text-base.font-bold.text-white
              %i.fas.fa-id-card.mr-2
              For Residents
          .p-6.grid.grid-cols-1.md:grid-cols-2.gap-6.items-center
            .flex.items-end.justify-center
              %img{ class: 'w-48 h-32 object-contain', src: asset_path('hero_cars/car3.png'), alt: 'Resident' }
            %ul.space-y-3
              - ["National / Local Driving License", "National ID / Emirates ID", "Residential Visa (may be accepted)"].each do |doc|
                %li.flex.items-start.gap-3
                  .w-6.h-6.rounded-full.flex.items-center.justify-center.flex-shrink-0{ style: "background: rgba(249,115,22,0.12); color: #F97316" }
                    %i.fas.fa-check.text-xs
                  %span.text-sm{ style: "color: var(--td-text)" }= doc
        / Tourists
        .rounded-2xl.overflow-hidden.border{ style: "background: var(--td-surface); border-color: var(--td-border)" }
          .px-6.py-4.border-b{ style: "background: linear-gradient(135deg, #1E293B, #0F172A); border-color: transparent" }
            %h3.text-base.font-bold.text-white
              %i.fas.fa-plane-arrival.mr-2
              For Tourists
          .p-6.grid.grid-cols-1.md:grid-cols-2.gap-6.items-center
            .flex.items-end.justify-center
              %img{ class: 'w-48 h-32 object-contain', src: asset_path('hero_cars/car4.png'), alt: 'Tourist' }
            %ul.space-y-3
              - ["Passport", "Visit / Tourist Visa", "Home Country Driving License", "International Driving Permit (IDP)"].each do |doc|
                %li.flex.items-start.gap-3
                  .w-6.h-6.rounded-full.flex.items-center.justify-center.flex-shrink-0{ style: "background: rgba(249,115,22,0.12); color: #F97316" }
                    %i.fas.fa-check.text-xs
                  %span.text-sm{ style: "color: var(--td-text)" }= doc

  / ═══════════════════════════════════════════════════════
  / TESTIMONIALS
  / ═══════════════════════════════════════════════════════
  %section.py-16{ style: "background: var(--td-surface2)" }
    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
      .text-center.mb-10
        %span.inline-block.text-xs.font-bold.uppercase.tracking-widest.mb-3.px-3.py-1.rounded-full{ style: "background: rgba(249,115,22,0.12); color: #F97316" } Reviews
        %h2.text-3xl.md:text-4xl.font-extrabold{ style: "color: var(--td-text)" } What Our Customers Say
      .grid.grid-cols-1.md:grid-cols-3.gap-6
        - (@testimonials || []).each do |t|
          %figure.rounded-2xl.p-6.flex.flex-col.justify-between.transition-all.duration-300.hover:-translate-y-1{ style: "background: var(--td-surface); border: 1px solid var(--td-border); box-shadow: var(--td-card-shadow)" }
            %div
              .flex.items-center.justify-between.mb-3
                .flex.items-center.gap-1.text-yellow-400
                  - t[:rating].times do
                    %i.fas.fa-star.text-sm
                  - (5 - t[:rating]).times do
                    %i.far.fa-star.text-sm{ style: 'color: var(--td-border)' }
                - if t[:relative_time_description]
                  .text-xs{ style: "color: var(--td-muted)" }= t[:relative_time_description]
