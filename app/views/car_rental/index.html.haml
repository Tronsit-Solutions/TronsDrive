- content_for :footer do
  = render 'shared/footer'

:javascript
  (function() {
    function initSlider(containerId, interval) {
      var container = document.getElementById(containerId);
      if (!container) return;
      var slides = Array.prototype.slice.call(container.querySelectorAll('img'));
      if (slides.length < 2) return;
      var active = 0;
      function show(index) {
        slides.forEach(function(img, i) {
          img.classList.toggle('opacity-0', i !== index);
          img.classList.toggle('opacity-100', i === index);
        });
      }
      var key = '_' + containerId + 'Interval';
      if (window[key]) { clearInterval(window[key]); window[key] = null; }
      show(active);
      window[key] = setInterval(function() { active = (active + 1) % slides.length; show(active); }, interval);
    }

    function initCarCarousels() {
      document.querySelectorAll('.carousel-track').forEach(function(track) {
        var category = track.dataset.category;
        var totalCars = parseInt(track.dataset.total);
        var currentPosition = parseInt(track.dataset.current) || 0;
        var prevBtn = document.querySelector('.carousel-prev[data-category="' + category + '"]');
        var nextBtn = document.querySelector('.carousel-next[data-category="' + category + '"]');
        if (!prevBtn || !nextBtn) return;
        var container = track.closest('.carousel-viewport');
        if (!container) return;
        var CARDS = window.innerWidth < 640 ? 1 : 4;
        var cardWidth = container.offsetWidth / CARDS;
        track.querySelectorAll('.carousel-item').forEach(function(c) {
          c.style.width = cardWidth + 'px';
          c.style.minWidth = cardWidth + 'px';
          c.style.maxWidth = cardWidth + 'px';
        });
        function maxPos() { return Math.max(0, totalCars - CARDS); }
        function updateBtns() {
          prevBtn.classList.toggle('hidden', currentPosition <= 0);
          nextBtn.classList.toggle('hidden', currentPosition >= maxPos() || totalCars <= CARDS);
        }
        function slide(dir) {
          if (dir === 'next' && currentPosition < maxPos()) currentPosition++;
          else if (dir === 'prev' && currentPosition > 0) currentPosition--;
          track.style.transform = 'translateX(-' + (currentPosition * cardWidth) + 'px)';
          track.dataset.current = currentPosition;
          updateBtns();
        }
        prevBtn.addEventListener('click', function() { slide('prev'); });
        nextBtn.addEventListener('click', function() { slide('next'); });
        updateBtns();
      });
    }

    function initAll() {
      initCarCarousels();
      initSlider('heroImageSlider', 4000);
      initSlider('promoSlider', 5000);
      initSlider('carHeroSlider', 3000);
    }

    document.addEventListener('DOMContentLoaded', initAll);
    document.addEventListener('turbo:load', initAll);
    document.addEventListener('turbo:render', initAll);
    if (document.readyState !== 'loading') setTimeout(initAll, 0);
  })();
