%footer{ style: "background: #020617; color: white" }
  .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8.py-12
    .grid.grid-cols-1.md:grid-cols-4.gap-8
      .space-y-4
        .flex.items-center.space-x-2
          .w-9.h-9.rounded-lg.flex.items-center.justify-center{ style: "background: linear-gradient(135deg, #F97316, #EA580C)" }
            %svg.w-5.h-5.text-white{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24", "stroke-width" => "2" }
              %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", d: "M12 4l8 4v4l-8 4-8-4V8l8-4z" }
          %span.text-xl.font-extrabold.tracking-tight
            Trons
            %span{ style: "color: #F97316" } Drive
        %p.text-sm.leading-relaxed{ style: "color: rgba(255,255,255,0.5)" }
          TronsDrive — your trusted partner for car rentals worldwide.
        .flex.gap-2.flex-wrap.mt-4
          = link_to AppConstants::FACEBOOK, target: '_blank', rel: 'noopener noreferrer', class: 'w-9 h-9 rounded-lg flex items-center justify-center hover:opacity-80 transition', style: 'background: rgba(255,255,255,0.07)', title: 'Facebook' do
            %svg.w-4.h-4{ fill: 'currentColor', viewBox: '0 0 24 24' }
              %path{ d: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' }
          = link_to AppConstants::INSTAGRAM, target: '_blank', rel: 'noopener noreferrer', class: 'w-9 h-9 rounded-lg flex items-center justify-center hover:opacity-80 transition', style: 'background: rgba(255,255,255,0.07)', title: 'Instagram' do
            %svg.w-4.h-4{ fill: 'currentColor', viewBox: '0 0 24 24' }
              %path{ d: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' }
          = link_to AppConstants::TWITTER, target: '_blank', rel: 'noopener noreferrer', class: 'w-9 h-9 rounded-lg flex items-center justify-center hover:opacity-80 transition', style: 'background: rgba(255,255,255,0.07)', title: 'X' do
            %svg.w-4.h-4{ fill: 'currentColor', viewBox: '0 0 24 24' }
              %path{ d: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' }
          = link_to AppConstants::YOUTUBE, target: '_blank', rel: 'noopener noreferrer', class: 'w-9 h-9 rounded-lg flex items-center justify-center hover:opacity-80 transition', style: 'background: rgba(255,255,255,0.07)', title: 'YouTube' do
            %svg.w-4.h-4{ fill: 'currentColor', viewBox: '0 0 24 24' }
              %path{ d: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z' }

      .space-y-3
        %h4.text-xs.font-bold.uppercase.tracking-widest{ style: "color: rgba(255,255,255,0.35)" } Quick Links
        %ul.space-y-2
          %li= link_to 'Browse Cars', cars_path, class: 'text-sm transition hover:text-orange-400', style: 'color: rgba(255,255,255,0.55)'
          %li= link_to 'List Your Car', new_vendor_request_path, class: 'text-sm transition hover:text-orange-400', style: 'color: rgba(255,255,255,0.55)'
          %li= link_to 'Blog', blogs_path, class: 'text-sm transition hover:text-orange-400', style: 'color: rgba(255,255,255,0.55)'

      .space-y-3
        %h4.text-xs.font-bold.uppercase.tracking-widest{ style: "color: rgba(255,255,255,0.35)" } Support
        %ul.space-y-2
          %li= link_to 'Terms & Conditions', terms_of_use_path, class: 'text-sm transition hover:text-orange-400', style: 'color: rgba(255,255,255,0.55)'

      .space-y-3
        %h4.text-xs.font-bold.uppercase.tracking-widest{ style: "color: rgba(255,255,255,0.35)" } Contact
        = link_to '+971502770780', 'tel:+971502770780', class: 'block text-sm transition hover:text-orange-400', style: 'color: rgba(255,255,255,0.55)'
        = link_to 'info@tronsitsolutions.com', 'mailto:info@tronsitsolutions.com', class: 'block text-sm transition hover:text-orange-400', style: 'color: rgba(255,255,255,0.55)'
        %p.text-sm{ style: "color: rgba(255,255,255,0.35)" } Business Center 1, M Floor, Meydan, Dubai, UAE, 415843
        .mt-4
          %p.text-xs.font-semibold.uppercase.tracking-widest.mb-3{ style: "color: rgba(255,255,255,0.35)" } Payments
          .flex.gap-2.flex-wrap.items-center
            %img{ src: asset_path('visa.png'), alt: 'Visa', class: 'h-5 opacity-60 hover:opacity-100 transition' }
            %img{ src: asset_path('mastercard.png'), alt: 'Mastercard', class: 'h-5 opacity-60 hover:opacity-100 transition' }
            %img{ src: asset_path('unionpay.png'), alt: 'UnionPay', class: 'h-5 opacity-60 hover:opacity-100 transition' }
            %img{ src: asset_path('apple-pay.png'), alt: 'Apple Pay', class: 'h-5 opacity-60 hover:opacity-100 transition' }
            %img{ src: asset_path('google-pay.png'), alt: 'Google Pay', class: 'h-5 opacity-60 hover:opacity-100 transition' }

  .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
    .mt-10.pt-6.flex.flex-col.md:flex-row.items-center.justify-between.gap-2{ style: "border-top: 1px solid rgba(249,115,22,0.25); box-shadow: 0 -1px 12px rgba(249,115,22,0.15);" }
      %p.text-xs{ style: "color: rgba(255,255,255,0.3)" }= "© #{Time.current.year} TronsDrive. All rights reserved."
      .flex.items-center.space-x-1
        .w-2.h-2.rounded-full{ style: "background: #F97316" }
        %span.text-xs{ style: "color: rgba(255,255,255,0.3)" } Drive the world
