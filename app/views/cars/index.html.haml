- content_for :title, @meta_title
- content_for :description, @meta_description
- content_for :head do
  :css
    html.dark body { background-color: #1E293B !important; }

/ Hero Section
%div.relative.h-64.flex.items-center.justify-center.mb-12.overflow-hidden
  %img.absolute.inset-0.w-full.h-full.object-cover.opacity-50{ src: image_path('listing/banner.jpg'), alt: 'Cars background' }

.max-w-7xl.mx-auto.px-4
  /Filters
  = render 'cars/filters'

  / Filter Summary
  = render 'cars/filter_summary'

  / Car Cards Grid
  %div.grid.grid-cols-1.sm:grid-cols-2.lg:grid-cols-3.gap-8.mb-16
    - @cars.each do |car|
      - cache [car, 'search_card'] do
        .bg-white.rounded-2xl.shadow-xl.overflow-hidden.flex.flex-col.justify-between.relative.transition.transform.hover:scale-105.hover:shadow-2xl
          / Car Image with Uniform Size
          = link_to car_path(car) do
            .relative.h-48.bg-gray-100.overflow-hidden
              = car_main_image(car, size: [400, 300])

              / Badges Container - Left Side (Stacked & Compact)
              / Badges Container - Left Side (Stacked & Compact)
              .absolute.top-2.left-2.z-10.flex.flex-col.gap-2.items-start
                / Featured Badge
                - if car.featured?
                  %span{class: "flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-yellow-400 text-gray-900 shadow-sm"}
                    %i{class: "fas fa-star mr-1 text-[10px]"}
                    Featured

                / Discount Badge
                - if car.has_discount?
                  .flex{class: "items-center gap-1 bg-gradient-to-r from-red-500 to-red-600 text-white px-2 py-0.5 rounded-full shadow-sm"}
                    %i{class: "fas fa-tag text-[10px]"}
                    %span{class: "text-[10px] font-bold"}= "#{car.discount_percentage}% OFF"

                / Driver Badge
                - if car.with_driver?
                  .flex{class: "items-center gap-1 bg-blue-600 text-white px-2 py-0.5 rounded-full shadow-sm"}
                    %i{class: "fas fa-user-tie text-[10px]"}
                    %span{class: "text-[10px] font-bold"} With Driver

              / Status Badge - Right Side
              .absolute.top-3.right-3.flex.flex-row.items-center.space-x-1
                - status_classes = {'Available' => 'bg-green-500 text-white','Rented' => 'bg-red-500 text-white'}[car.status] || 'bg-orange-500 text-white'
                %span.inline-block.rounded-full.text-xs.font-semibold.px-2.py-1{ class: status_classes }= car.status
              
            .p-6.flex-1.flex.flex-col
              %div.flex.items-center.justify-between.mb-2
                %h3.text-lg.font-bold.text-gray-900.group-hover:text-blue-600.transition-colors
                  - if car.category == 'Limousine'
                    = car.brand
                  - else
                    = "#{car.brand} #{car.model}"
                - unless car.category == 'Limousine'
                  %span.text-sm.text-gray-500= car.year
              
              - if car.category == 'Limousine'
                %div.text-gray-700.mb-3
                  %span.text-gray-500 Limousine
              - else
                %div.text-gray-700.mb-3
                  = car.color
                  - if car.with_driver?
                    %span.text-gray-500.ml-2 •
                    %span.text-gray-500= "#{car.seats || 5} Seats"
                    %span.text-gray-500.ml-2 •
                    %span.text-gray-500= "#{car.luggage_capacity || 0} Bags"
                  - elsif car.category.present?
                    %span.text-gray-500.ml-2 •
                    %span.text-gray-500= car.category.capitalize

              %div.flex.items-baseline.justify-between.mb-4
                %div.h-14.flex.flex-col.justify-end
                  - if car.category == 'Limousine'
                    - if car.has_discount?
                      .flex.flex-col
                        %span.text-lg.text-gray-400.line-through= "AED #{car.hourly_price}"
                        %span.text-2xl.font-bold.text-red-600= "AED #{car.discounted_hourly_price.round(2)}"
                    - else
                      %span.text-2xl.font-bold{style: 'color: #F97316'}= "AED #{car.hourly_price}"
                  - elsif car.with_driver?
                    - if car.has_discount?
                      .flex.flex-col
                        %span.text-lg.text-gray-400.line-through= "AED #{car.five_hours_charge}"
                        %span.text-2xl.font-bold.text-red-600= "AED #{car.discounted_five_hours_charge.round(2)}"
                    - else
                      %span.text-2xl.font-bold{style: 'color: #F97316'}= car.five_hours_charge ? "AED #{car.five_hours_charge}" : 'AED 0'
                  - elsif car.has_discount?
                    .flex.flex-col
                      %span.text-lg.text-gray-400.line-through= number_to_currency(car.daily_price)
                      %span.text-2xl.font-bold.text-red-600= number_to_currency(car.discounted_daily_price)
                  - else
                    %span.text-2xl.font-bold{style: 'color: #F97316'}= car.daily_price ? number_to_currency(car.daily_price) : 'N/A'
                %span.text-sm.text-gray-500
                  - if car.category == 'Limousine'
                    \/hr
                  - elsif car.with_driver?
                    \/5h Service
                  - else
                    \/day
 
  / SEO Content Section
  - allowed_categories = %w[convertible economy electric hybrid luxury sports suv truck van]
  - allowed_brands = %w[aston-martin audi bentley bmw cadillac chevrolet gmc kia lamborghini land-rover lexus mazda mini mitsubishi nissan rolls-royce]
  
  - category_partials = allowed_categories.each_with_object({}) { |c, h| h[c] = "cars/#{c}_description" }
  - brand_partials = allowed_brands.each_with_object({}) { |b, h| h[b] = "cars/#{b}_description" }
  
  - if params[:category].present? && (partial = category_partials[params[:category].to_s.downcase])
    = render partial
  - elsif params[:brand].present? && (partial = brand_partials[params[:brand].to_s.downcase])
    = render partial

/ FOOTER
- content_for :footer do
  = render 'shared/footer'
