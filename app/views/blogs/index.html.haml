%div.min-h-screen.bg-white
  .py-5

    / HERO SECTION
    %section.relative.h-96.bg-cover.bg-center.flex.items-center.justify-center{style: "background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url(#{asset_path('blogs-banner.png')})"}
      .text-center.text-white.px-4
        %h1.text-5xl.font-bold.mb-4
          Car Rental
          %span.text-yellow-400 Insights
        %p.text-xl.text-gray-200
          Expert tips, guides, and stories to enhance your car rental experience
    
    / BLOG CARDS GRID
    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8.py-16
      .grid.grid-cols-1.md:grid-cols-2.lg:grid-cols-3.gap-8
        - @blogs.each do |blog|
          - cache [blog, 'blog_card'] do
            = link_to blog_path(blog.slug), class: 'group cursor-pointer' do
              .bg-white.rounded-lg.overflow-hidden.shadow-md.hover:shadow-xl.transition-shadow.duration-300
                
                / IMAGE CONTAINER
                .relative.h-48.overflow-hidden.bg-gray-200
                  - if blog.featured_image.attached?
                    %img.w-full.h-full.object-cover.group-hover:scale-105.transition-transform.duration-300{src: url_for(blog.featured_image), alt: blog.title}
                  - else
                    .w-full.h-full.bg-gray-300.flex.items-center.justify-center
                      %span.text-gray-400 No Image
                  
                  / CATEGORY BADGE
                  %span.absolute.top-4.left-4.px-3.py-1.rounded-full.text-sm.font-semibold.text-white{style: "background-color: #F97316;"}
                    = blog.category

                / CONTENT CONTAINER
                .p-6
                  / DATE & AUTHOR
                  .flex.items-center.text-gray-500.text-sm.mb-3.space-x-4
                    %span
                      %i.far.fa-calendar.mr-1
                      = blog.published_at.strftime('%b %d, %Y')
                    %span
                      %i.far.fa-user.mr-1
                      = blog.author_name

                  / TITLE
                  %h3.text-xl.font-bold.mb-3.line-clamp-2{style: "color: #F97316;"}
                    = blog.title

                  / CONTENT PREVIEW
                  %p.text-gray-600.text-sm.mb-4.line-clamp-3
                    = truncate(strip_tags(blog.content), length: 150)

                  / READ MORE LINK
                  .font-semibold.text-sm{style: "color: #F97316;"}
                    Read More →
    
    / EMPTY STATE
    - if @blogs.empty?
      .min-h-96.flex.items-center.justify-center.py-20
        .text-center.max-w-lg.px-6
          / DECORATIVE BACKGROUND ELEMENTS
          .relative
            / Animated circles in background
            .absolute.top-0.left-0.w-32.h-32.rounded-full{style: "background-color: rgba(249,115,22,0.05); animation: float 6s ease-in-out infinite;"}
            .absolute.bottom-0.right-0.w-40.h-40.rounded-full{style: "background-color: rgba(249,115,22,0.03); animation: float 8s ease-in-out infinite 1s;"}

            / MAIN ICON - Animated car with blog/document
            .mb-8.relative.z-10
              .inline-block.relative
                %svg.w-32.h-32{viewBox: "0 0 100 100", style: "animation: bounce 2s ease-in-out infinite;"}
                  / Blog document icon
                  %g{style: "fill: #F97316; opacity: 0.8;"}
                    %rect{x: "20", y: "15", width: "40", height: "50", rx: "3"}
                    %line{x1: "30", y1: "30", x2: "50", y2: "30", stroke: "white", "stroke-width": "2", "stroke-linecap": "round"}
                    %line{x1: "30", y1: "42", x2: "50", y2: "42", stroke: "white", "stroke-width": "2", "stroke-linecap": "round"}
                    %line{x1: "30", y1: "54", x2: "50", y2: "54", stroke: "white", "stroke-width": "2", "stroke-linecap": "round"}

                  / Small car icon
                  %g{style: "fill: #F97316; opacity: 0.9;"}
                    %ellipse{cx: "65", cy: "70", rx: "18", ry: "12"}
                    %rect{x: "50", y: "65", width: "30", height: "8"}
                    %circle{cx: "55", cy: "78", r: "2", fill: "white"}
                    %circle{cx: "75", cy: "78", r: "2", fill: "white"}

            / HEADING
            %h2.text-3xl.font-bold.mb-3{style: "color: #F97316;"}
              No Blogs Yet!
            
            / SUBHEADING
            %p.text-gray-500.text-lg.mb-2
              The road to great content is still being paved.
            
            / DESCRIPTION
            %p.text-gray-400.text-base.mb-8
              Our team is crafting amazing insights, tips, and guides about car rentals. Buckle up—something exciting is coming your way soon!

            / CTA BUTTONS
            .flex.flex-col.sm:flex-row.gap-4.justify-center.mt-10
              = link_to 'Explore Our Fleet', cars_path, class: 'px-6 py-3 rounded-lg font-semibold transition-all duration-300 hover:scale-105 text-white', style: 'background-color: #F97316;'

- content_for :footer do
  = render 'shared/footer'
